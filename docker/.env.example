# Variáveis de ambiente do stack Docker da BDLP.
# Copie este arquivo para `.env` (mesmo diretório) e ajuste o que precisar.
# O `.env` é gitignored — defaults aqui valem para o caso de não existir override.

# ─────────────────────────────────────────────────────────────────────────────
# Portas expostas no host. Trocar quando houver conflito na máquina.
# Ex.: na máquina do bcgsantos, a porta 8000 está reservada pelo kernel,
# por isso PORTAL_PORT=8001 é necessário lá. Outras máquinas podem usar
# o default.
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_PORT=5432
NOURAU_PORT=8080
PORTAL_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# Credenciais do Postgres (dev local). Não usar em produção.
# `php` é o usuário admin que o Nou-Rau usa para schema/seed.
# `portal_reader` é o usuário read-only que o Django Portal consome.
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=nourau
POSTGRES_USER=php
POSTGRES_PASSWORD=abc123
PORTAL_DB_USER=portal_reader
PORTAL_DB_PASSWORD=portal_reader_dev

# ─────────────────────────────────────────────────────────────────────────────
# Django (portal). DEBUG=true só para dev. Trocar SECRET_KEY antes de
# qualquer deploy fora do laptop.
# ─────────────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=insecure-dev-key-change-in-production
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# URLs que cada serviço usa para se referir aos outros / a si mesmo.
# Manter coerente com as portas acima.
# ─────────────────────────────────────────────────────────────────────────────
NOURAU_SITE_URL=http://localhost:8080
NOURAU_WEBMASTER_EMAIL=nourau@localhost
PORTAL_URL=http://localhost:8000
