FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Dependências do sistema para psycopg2
RUN apt-get update && apt-get install -y \
        libpq-dev \
        gcc \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Instalar dependências Python (extraídas do pyproject.toml)
COPY pyproject.toml /app/
RUN pip install --no-cache-dir \
    "django>=5.1,<6.0" \
    "psycopg2-binary>=2.9" \
    "gunicorn>=22.0" \
    "django-environ>=0.11" \
    "openpyxl>=3.1" \
    "whitenoise>=6.7"

# Copiar código do portal
COPY portal/ /app/

# Coletar arquivos estáticos
RUN DJANGO_SECRET_KEY=build-placeholder python manage.py collectstatic --noinput 2>/dev/null || true

EXPOSE 8000

CMD ["gunicorn", "portal.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "3"]
